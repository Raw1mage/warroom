{
  "schema_version": 1,
  "targets": [
    {
      "id": "rawdb",
      "enabled": true,
      "sources": [
        "host_health_remote",
        "file_station_remote",
        "drive_remote",
        "nas_home_log_remote",
        "nas_system_log_remote"
      ],
      "host_health_remote": {
        "host": "192.168.100.40",
        "user": "yeatsluo",
        "timeout_seconds": 90
      },
      "file_station_remote": {
        "host": "192.168.100.40",
        "user": "yeatsluo",
        "db_path": "/volume1/@database/synolog/.DSMFMXFERDB",
        "limit": 50,
        "timeout_seconds": 90
      },
      "nas_home_log_remote": {
        "host": "192.168.100.40",
        "user": "yeatsluo",
        "log_paths": [
          "/var/log/messages",
          "/var/log/synosys.log",
          "/var/log/synolog/synosys.log",
          "/var/log/samba/log.smbd",
          "/var/log/samba/log.nmbd",
          "/var/log/nginx/error.log",
          "/var/log/httpd/access_log",
          "/var/log/httpd/error_log",
          "/var/log/rsyncd.log",
          "/var/log/ftp.log",
          "/var/log/vsftpd.log",
          "/var/log/auth.log",
          "/var/log/scemd.log",
          "/var/log/synoscgi.log",
          "/var/log/synoscheduler.log",
          "/var/log/synopkg.log"
        ],
        "tail_lines": 2000,
        "limit": 50,
        "timeout_seconds": 90
      },
      "nas_system_log_remote": {
        "host": "192.168.100.40",
        "user": "yeatsluo",
        "log_paths": [
          "/var/log/messages",
          "/var/log/synosys.log",
          "/var/log/synolog/synosys.log",
          "/var/log/samba/log.smbd",
          "/var/log/samba/log.nmbd",
          "/var/log/samba/log.winbindd",
          "/var/log/nginx/access.log",
          "/var/log/nginx/error.log",
          "/var/log/httpd/access_log",
          "/var/log/httpd/error_log",
          "/var/log/rsyncd.log",
          "/var/log/ftp.log",
          "/var/log/vsftpd.log",
          "/var/log/auth.log",
          "/var/log/scemd.log",
          "/var/log/synoscgi.log",
          "/var/log/synoscheduler.log",
          "/var/log/synopkg.log",
          "/var/log/synolog/synosmb.log",
          "/var/log/synolog/synofile.log",
          "/var/log/synolog/synoshare.log"
        ],
        "tail_lines": 2000,
        "limit": 200,
        "timeout_seconds": 90
      }
    },
    {
      "id": "thesmart",
      "display_name": "利善美智能",
      "enabled": true,
      "sources": [
        "host_health_remote",
        "file_station_remote",
        "nas_home_log_remote",
        "nas_system_log_remote"
      ],
      "host_health_remote": {
        "host": "nas.wuyang.co",
        "user": "wuyangadmin",
        "timeout_seconds": 90
      },
      "file_station_remote": {
        "host": "nas.wuyang.co",
        "user": "wuyangadmin",
        "db_path": "/volume1/@database/synolog/.DSMFMXFERDB",
        "limit": 50,
        "timeout_seconds": 90
      },
      "drive_remote": {
        "host": "nas.wuyang.co",
        "user": "wuyangadmin",
        "sync_root": "/volume1/@synologydrive/@sync",
        "limit": 100,
        "timeout_seconds": 90
      },
      "nas_home_log_remote": {
        "host": "nas.wuyang.co",
        "user": "wuyangadmin",
        "log_paths": [
          "/var/log/messages",
          "/var/log/synosys.log",
          "/var/log/synolog/synosys.log",
          "/var/log/samba/log.smbd",
          "/var/log/samba/log.nmbd",
          "/var/log/nginx/error.log",
          "/var/log/httpd/access_log",
          "/var/log/httpd/error_log",
          "/var/log/rsyncd.log",
          "/var/log/ftp.log",
          "/var/log/vsftpd.log",
          "/var/log/auth.log",
          "/var/log/scemd.log",
          "/var/log/synoscgi.log",
          "/var/log/synoscheduler.log",
          "/var/log/synopkg.log"
        ],
        "tail_lines": 2000,
        "limit": 50,
        "timeout_seconds": 30
      },
      "nas_system_log_remote": {
        "host": "nas.wuyang.co",
        "user": "wuyangadmin",
        "log_paths": [
          "/var/log/messages",
          "/var/log/synosys.log",
          "/var/log/synolog/synosys.log",
          "/var/log/samba/log.smbd",
          "/var/log/samba/log.nmbd",
          "/var/log/samba/log.winbindd",
          "/var/log/nginx/access.log",
          "/var/log/nginx/error.log",
          "/var/log/httpd/access_log",
          "/var/log/httpd/error_log",
          "/var/log/rsyncd.log",
          "/var/log/ftp.log",
          "/var/log/vsftpd.log",
          "/var/log/auth.log",
          "/var/log/scemd.log",
          "/var/log/synoscgi.log",
          "/var/log/synoscheduler.log",
          "/var/log/synopkg.log",
          "/var/log/synolog/synosmb.log",
          "/var/log/synolog/synofile.log",
          "/var/log/synolog/synoshare.log"
        ],
        "tail_lines": 2000,
        "limit": 200,
        "timeout_seconds": 90
      }
    },
    {
      "id": "unraid",
      "display_name": "Unraid",
      "enabled": true,
      "sources": [
        "host_health_remote",
        "nas_system_log_remote",
        "auth_log_remote",
        "network_socket_remote",
        "docker_service_remote"
      ],
      "host_health_remote": {
        "host": "unraid",
        "timeout_seconds": 90
      },
      "nas_system_log_remote": {
        "host": "unraid",
        "log_paths": [
          "/var/log/syslog",
          "/var/log/messages",
          "/var/log/kern.log",
          "/var/log/daemon.log",
          "/var/log/auth.log"
        ],
        "tail_lines": 2000,
        "limit": 200,
        "timeout_seconds": 90
      },
      "auth_log_remote": {
        "host": "unraid",
        "log_paths": [
          "/var/log/auth.log",
          "/var/log/secure",
          "/var/log/messages"
        ],
        "tail_lines": 2000,
        "limit": 100,
        "timeout_seconds": 90
      },
      "network_socket_remote": {
        "host": "unraid",
        "top_limit": 20,
        "timeout_seconds": 90
      },
      "docker_service_remote": {
        "host": "unraid",
        "limit": 100,
        "timeout_seconds": 90
      }
    }
  ]
}

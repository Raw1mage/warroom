GRAFANA_PORT=3000
GRAFANA_ROOT_URL=http://localhost:3000/warroom/
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-local-only
PROMETHEUS_PORT=9090
LOKI_PORT=3100
SYNOLOGY_NGINX_LOG_DIR=./synology-nginx-logs
SYNOLOGY_NGINX_SYSLOG_TCP_PORT=1514
SYNOLOGY_NGINX_SYSLOG_UDP_PORT=1514
WARROOM_DLP_FILE_COLLECTOR_PORT=8010
WARROOM_DLP_COLLECTOR_SOURCES=host_health_remote,file_station_remote,nas_home_log_remote,nas_system_log_remote
WARROOM_DLP_COLLECTOR_INTERVAL_SECONDS=30
WARROOM_NAS_TARGETS_CONFIG=/config/nas-targets.json

# SSH identity single source of truth for transient NAS payload collection.
# Keep private keys on the host; docker-compose mounts this directory read-only
# at the same absolute path inside warroom-dlp-file-collector.
WARROOM_SSH_DIR=/home/pkcs12/.ssh
WARROOM_SSH_IDENTITY_FILE=/home/pkcs12/.ssh/id_ed25519

# Optional local MaxMind-compatible MMDB path mounted from ./geoip.
# Example after placing a GeoLite2/DB-IP Lite city database under ./geoip:
# WARROOM_GEOIP_MMDB_PATH=/geoip/GeoLite2-City.mmdb
WARROOM_GEOIP_MMDB_PATH=

# Legacy single-target fallback. Prefer config/nas-targets.json for new hosts.
WARROOM_FILE_STATION_REMOTE_HOST=rawdb
# Leave empty to use local ssh config for Host rawdb, or set an explicit SSH user.
WARROOM_FILE_STATION_REMOTE_USER=
WARROOM_FILE_STATION_NAS_HOST=rawdb
WARROOM_FILE_STATION_REMOTE_LIMIT=50
WARROOM_FILE_STATION_REMOTE_TIMEOUT_SECONDS=90
WARROOM_FILE_STATION_DB_PATH=/volume1/@database/synolog/.DSMFMXFERDB

# Local secrets and credentials
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa*
id_ed25519*

# Runtime data
incoming/
synology-nginx-logs/*
*.log
*.sqlite
*.db
*.db-wal
*.db-shm
geoip/*.mmdb
__pycache__/
*.py[cod]

# Per-server runtime spool/state (keep directory skeletons only)
rawdb/data/**/*
!rawdb/data/**/
!rawdb/data/**/.gitkeep
thesmart/data/**/*
!thesmart/data/**/
!thesmart/data/**/.gitkeep

# Device / service runtime state (ban lists, snapshots, log streams,
# ssh known_hosts, baseline reports — local-only, regenerated at runtime)
devices/**/state/
devices/**/snapshots/
devices/**/known_hosts
services/**/state/

# Private planning / event artifacts retained locally only
.specbase/
docs/events/
specs/
refs/
plans/**
!plans/
!plans/20260427_warroom_monitoring_platform/
!plans/20260427_warroom_monitoring_platform/drawmiat-multilevel-zh/
!plans/20260427_warroom_monitoring_platform/drawmiat-multilevel-zh/*.svg
!plans/20260427_warroom_monitoring_platform/miat-compliant/
!plans/20260427_warroom_monitoring_platform/miat-compliant/*.json
!plans/20260427_warroom_monitoring_platform/miat-compliant/*.svg

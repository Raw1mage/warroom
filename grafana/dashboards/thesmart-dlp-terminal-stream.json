  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "把大量 raw log 重新歸類成可決策的證據語意：外流/下載、開檔/預覽、NAS 檔案服務活動、主機健康、系統服務事件、能力缺口與其他。只統計已進 Loki 的 evidence，不推估缺漏。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 10,
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "single",
          "sort": "desc"
        }
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\", action=~\"webapp_file_download|webapp_file_export\"}[$__range])) or vector(0)",
          "legendFormat": "檔案外流/下載匯出",
          "queryType": "instant",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\", action=~\"webapp_file_open|webapp_file_preview|public_share_page_load|sharing_link_access\"}[$__range])) or vector(0)",
          "legendFormat": "開檔/預覽/分享瀏覽",
          "queryType": "instant",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\", action=~\"file_activity|file_read|file_write|file_delete|file_rename\"}[$__range])) or vector(0)",
          "legendFormat": "NAS 檔案服務活動",
          "queryType": "instant",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\", source_app=\"nas_host_health\"}[$__range])) or vector(0)",
          "legendFormat": "主機健康/資源監測",
          "queryType": "instant",
          "refId": "D"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\", source_channel=\"nas_system_log\"}[$__range])) or vector(0)",
          "legendFormat": "NAS 系統/服務事件",
          "queryType": "instant",
          "refId": "E"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\", action=\"capability_gap\"}[$__range])) or vector(0)",
          "legendFormat": "能力缺口/收集失敗",
          "queryType": "instant",
          "refId": "F"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\", action!~\"webapp_file_download|webapp_file_export|webapp_file_open|webapp_file_preview|public_share_page_load|sharing_link_access|file_activity|file_read|file_write|file_delete|file_rename|capability_gap\", source_app!=\"nas_host_health\", source_channel!=\"nas_system_log\"}[$__range]))",
          "legendFormat": "其他/未歸類 evidence",
          "queryType": "instant",
          "refId": "G"
        }
      ],
      "title": "DLP 綜合 evidence insight 比例",
      "type": "piechart"
    },

        "options": [],
        "query": "label_values({job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\"}, nas_host)",
        "refresh": 1,
        "regex": "^thesmart$",
        "sort": 1,
        "type": "query"
      }
    ]
  },

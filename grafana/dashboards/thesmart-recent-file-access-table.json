  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "doc",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "開啟檔案證據總覽",
      "tooltip": "切換到 DLP file evidence dashboard",
      "type": "dashboard",
      "uid": "thesmart-dlp-file-evidence"
    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "最近被存取的檔案彙總。以檔名、使用者、途徑與 IP 去重，證據筆數表示同一活動在底層 DB/log 中出現的 row 數；缺 IP 或使用者時保持空值，不推測補值。",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 18,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "topk(100, sum by (file_name, actor, source_app, source_ip) (count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"$nas\", source_app!=\"collector\", action=~\"webapp_file_open|webapp_file_preview|webapp_file_download|webapp_file_export|file_read|file_write|file_delete|file_rename\"} | json | file_name != \"\" | label_format file_name=\"{{.file_name}}\", actor=\"{{.actor}}\", source_app=\"{{.source_app}}\", source_ip=\"{{.source_ip}}\" [$__range])))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "最近被存取的檔案（去重彙總）",
      "transformations": [
        {
          "id": "seriesToRows",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Metric": 0,
              "Value": 1
            },
            "renameByName": {
              "Metric": "檔案 / 使用者 / 途徑 / IP",
              "Value": "證據筆數"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "preload": false,
  "refresh": "10s",
  "schemaVersion": 40,
  "tags": [
    "warroom",
    "dlp",
    "file-access",
    "thesmart",
    "利善美智能",
    "data-security"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "thesmart",
          "value": "thesmart"
        },
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "definition": "label_values({job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\"}, nas_host)",
        "hide": 0,
        "includeAll": false,
        "label": "NAS",
        "multi": false,
        "name": "nas",
        "options": [],
        "query": "label_values({job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\"}, nas_host)",
        "refresh": 1,
        "regex": "^thesmart$",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-30m",
    "to": "now"

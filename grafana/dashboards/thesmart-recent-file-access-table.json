    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "最近被存取的檔案清單。欄位直接來自 Loki JSON payload：時間、file_name、actor、source_app、source_ip；缺 IP 或使用者時保持空值，不推測補值。",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 18,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "{job=\"warroom-dlp-event-collector\", nas_host=\"$nas\", source_app!=\"collector\", action=~\"webapp_file_open|webapp_file_preview|webapp_file_download|webapp_file_export|file_activity|file_read|file_write|file_delete|file_rename\"} | json | file_name != \"\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "最近被存取的檔案",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "format": "json",
            "replace": false,
            "source": "Line"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "__error__": true,
              "__error_details__": true,
              "action": true,
              "collector": true,
              "confidence": true,
              "display_path": true,
              "event_id": true,
              "folder_path": true,
              "ingested_at": true,
              "nas_host": true,
              "network_protocol": true,
              "observed_at": true,
              "policy_notes": true,
              "protocol": true,
              "size_bytes": true,
              "source_channel": true,
              "source_country": true,
              "source_key": true,
              "source_region": true
            },
            "indexByName": {
              "Time": 0,
              "file_name": 1,
              "actor": 2,
              "source_app": 3,
              "source_ip": 4
            },
            "renameByName": {
              "Time": "時間",
              "actor": "使用者",
              "file_name": "檔名",
              "source_app": "途徑（app名）",
              "source_ip": "IP"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "preload": false,
  "refresh": "10s",
  "schemaVersion": 40,
  "tags": [
    "warroom",
    "dlp",
    "file-access",
    "thesmart",
    "利善美智能",
    "data-security"
  ],

      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "開啟 DLP 統計圖表",
      "tooltip": "切換到 Drive/File/Sharing 活動統計 dashboard",
      "type": "dashboard",
      "uid": "warroom-dlp-web-ingress"
    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "像 terminal 一樣顯示 DLP 證據時間序。當圖表不足以理解上下文時，從這裡查看完整事件流。",
      "gridPos": {
        "h": 22,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 10,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": false,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": false,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "{job=\"synology-nginx\", source_surface=\"web_ingress_nginx\", route_family=~\"drive|file|sharing\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Terminal / DLP 綜合證據流",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "聚焦 viewer、download、sharing、preview、API 等關鍵字，協助快速找出開檔、預覽、下載或分享相關活動。",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "id": 11,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": false,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "{job=\"synology-nginx\", source_surface=\"web_ingress_nginx\", route_family=~\"drive|file|sharing\"} |~ \"(?i)(viewer|download|sharing|preview|thumb|image|photo|entry.cgi|webapi)\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Terminal / 檔案動作候選事件",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "顯示由 Warroom 本地 DLP event collector 推送的正規化 Drive / File Station 事件。查詢只使用 bounded labels，不依檔名、路徑、使用者或來源 IP 分組。",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "id": 12,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": false,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "{job=\"warroom-dlp-event-collector\", source_app=~\"synology_drive|file_station\"} | json | line_format \"{{__timestamp__ | date \\\"2006-01-02T15:04:05Z07:00\\\"}} {{if .source_ip}}{{.source_ip}}{{else}}-{{end}} {{if .actor}}{{.actor}}{{else}}-{{end}} {{.source_app}} {{.action}} \\\"{{if .display_path}}{{.display_path}}{{else if .file_name}}{{.file_name}}{{else}}-{{end}}\\\" {{if .size_bytes}}{{if ge (float64 .size_bytes) 1073741824.0}}{{printf \\\"%.3f GB\\\" (divf .size_bytes 1073741824)}}{{else if ge (float64 .size_bytes) 1048576.0}}{{printf \\\"%.3f MB\\\" (divf .size_bytes 1048576)}}{{else}}{{printf \\\"%.3f KB\\\" (divf .size_bytes 1024)}}{{end}}{{else}}-{{end}} {{if .network_protocol}}{{.network_protocol}}{{else if .protocol}}{{.protocol}}{{else}}-{{end}} {{if .source_country}}{{.source_country}}{{if .source_region}}/{{.source_region}}{{end}}{{else}}-{{end}}\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Collector / 正規化 Drive 與 File Station 事件",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "依 bounded action 與 source_app label 統計 collector 事件，用於快速確認預覽、下載、匯出等正規化事件是否進入 Loki。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 42
      },
      "id": 13,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum by (source_app, action) (count_over_time({job=\"warroom-dlp-event-collector\", source_app=~\"synology_drive|file_station\"}[5m]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Collector / 動作與來源統計",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "顯示 collector fail-fast 或錯誤訊號。正常情況下應為空；若出現記錄，代表輸入 JSON、必填欄位或 Loki push 發生明確失敗。",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 42
      },
      "id": 14,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "{job=\"warroom-dlp-event-collector\"} |~ \"(?i)(\\\"ok\\\":false|missing_required_fields|invalid_json|loki_push_failed|input_missing)\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Collector / Fail-fast 錯誤事件",
      "type": "logs"
    }
  ],
  "preload": false,
  "refresh": "5s",
  "schemaVersion": 40,
  "tags": [
    "warroom",

  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "把大量 raw log 重新歸類成可決策的證據語意：外流/下載、開檔/預覽、NAS 檔案服務活動、主機健康、系統服務事件、能力缺口與其他。只統計已進 Loki 的 evidence，不推估缺漏。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 10,
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "single",
          "sort": "desc"
        }
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"lishanmei\", action=~\"webapp_file_download|webapp_file_export\"}[$__range])) or vector(0)",
          "legendFormat": "檔案外流/下載匯出",
          "queryType": "instant",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"lishanmei\", action=~\"webapp_file_open|webapp_file_preview|public_share_page_load|sharing_link_access\"}[$__range])) or vector(0)",
          "legendFormat": "開檔/預覽/分享瀏覽",
          "queryType": "instant",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"lishanmei\", action=~\"file_activity|file_read|file_write|file_delete|file_rename\"}[$__range])) or vector(0)",
          "legendFormat": "NAS 檔案服務活動",
          "queryType": "instant",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"lishanmei\", source_app=\"nas_host_health\"}[$__range])) or vector(0)",
          "legendFormat": "主機健康/資源監測",
          "queryType": "instant",
          "refId": "D"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"lishanmei\", source_channel=\"nas_system_log\"}[$__range])) or vector(0)",
          "legendFormat": "NAS 系統/服務事件",
          "queryType": "instant",
          "refId": "E"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"lishanmei\", action=\"capability_gap\"}[$__range])) or vector(0)",
          "legendFormat": "能力缺口/收集失敗",
          "queryType": "instant",
          "refId": "F"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"lishanmei\", action!~\"webapp_file_download|webapp_file_export|webapp_file_open|webapp_file_preview|public_share_page_load|sharing_link_access|file_activity|file_read|file_write|file_delete|file_rename|capability_gap\", source_app!=\"nas_host_health\", source_channel!=\"nas_system_log\"}[$__range]))",
          "legendFormat": "其他/未歸類 evidence",
          "queryType": "instant",
          "refId": "G"
        }
      ],
      "title": "DLP 綜合 evidence insight 比例",
      "type": "piechart"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "聚焦 viewer、download、sharing、preview、API 等關鍵字，協助快速找出開檔、預覽、下載或分享相關活動。",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 11,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": false,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "{job=\"warroom-dlp-event-collector\", nas_host=\"lishanmei\"} | json | action=~\"webapp_file_open|webapp_file_preview|webapp_file_download|webapp_file_export|file_read|file_write|file_delete|file_rename\" | line_format \"{{.source_app}} {{.action}} {{if .display_path}}{{.display_path}}{{else}}-{{end}}\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Terminal / 檔案動作候選事件",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "顯示由 Warroom 本地 DLP event collector 推送的正規化 Drive / File Station 事件。查詢只使用 bounded labels，不依檔名、路徑、使用者或來源 IP 分組。",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "id": 12,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": false,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "{job=\"warroom-dlp-event-collector\", nas_host=\"lishanmei\", source_app=~\"synology_drive|file_station|nas_file_service\"} | json | line_format \"{{__timestamp__ | date \\\"2006-01-02T15:04:05Z07:00\\\"}} {{if .source_ip}}{{.source_ip}}{{else}}-{{end}} {{if .actor}}{{.actor}}{{else}}-{{end}} {{.source_app}} {{.action}} \\\"{{if .display_path}}{{.display_path}}{{else if .file_name}}{{.file_name}}{{else}}-{{end}}\\\" {{if .network_protocol}}{{.network_protocol}}{{else if .protocol}}{{.protocol}}{{else}}-{{end}}\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Collector / 正規化 Drive 與 File Station 事件",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "依 bounded action 與 source_app label 統計 collector 事件，用於快速確認預覽、下載、匯出等正規化事件是否進入 Loki。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 36
      },
      "id": 13,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum by (source_app, action) (count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"lishanmei\", source_app=~\"synology_drive|file_station|nas_file_service\"}[5m]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Collector / 動作與來源統計",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "顯示 collector fail-fast 或錯誤訊號。正常情況下應為空；若出現記錄，代表輸入 JSON、必填欄位或 Loki push 發生明確失敗。",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 36
      },
      "id": 14,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "{job=\"warroom-dlp-event-collector\", nas_host=\"lishanmei\"} |~ \"(?i)(\\\"ok\\\":false|missing_required_fields|invalid_json|loki_push_failed|input_missing|capability_gap)\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Collector / Fail-fast 錯誤事件",
      "type": "logs"
    }

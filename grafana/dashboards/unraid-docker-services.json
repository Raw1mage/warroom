          "datasource": {"type": "loki", "uid": "loki"},
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=~\"$host\", source_channel=\"docker_service\", source_app=\"host_docker\"}[5m])) or vector(0)",

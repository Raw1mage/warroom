    {
      "id": 60,
      "type": "table",
      "title": "Currently banned — mail-originated",
      "description": "IPs in router DROP list where reason starts with 'mail' OR 'cross-channel'. Pulled from /var/lib/securityscan-style state via the exporter.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 63
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "asusrouter_ban_banned_at_seconds",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "asusrouter_ban_expires_at_seconds",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "asusrouter_ban_expires_at_seconds - time()",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "warroom_ip_info",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "^ip$",
            "renamePattern": "src_ip"
          }
        },
        {
          "id": "joinByField",
          "options": {
            "byField": "src_ip",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "instance": true,
              "instance 1": true,
              "instance 2": true,
              "instance 3": true,
              "instance 4": true,
              "job": true,
              "job 1": true,
              "job 2": true,
              "job 3": true,
              "job 4": true,
              "device": true,
              "device 1": true,
              "device 2": true,
              "device 3": true,
              "latitude": true,
              "longitude": true,
              "state": true
            },
            "indexByName": {
              "src_ip": 0,
              "country_iso": 1,
              "city": 2,
              "asn_org": 3,
              "Value #A": 4,
              "Value #B": 5,
              "Value #C": 6
            },
            "renameByName": {
              "src_ip": "IP",
              "country_iso": "Country",
              "city": "City",
              "asn_org": "AS Org",
              "Value #A": "Banned at",
              "Value #B": "Expires at",
              "Value #C": "Remaining"
            }
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "IP",
                "Country",
                "City",
                "AS Org",
                "Banned at",
                "Expires at",
                "Remaining"
              ]
            }
          }
        },
        {
          "id": "filterByValue",
          "options": {
            "filters": [
              {
                "fieldName": "Remaining",
                "config": {
                  "id": "greater",
                  "options": {
                    "value": 0
                  }
                }
              }
            ],
            "type": "include",
            "match": "any"

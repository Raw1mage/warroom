    },
    {
      "id": 2,
      "type": "stat",
      "title": "Postscreen rejects",
      "description": "DNSBL hits / HANGUP / BARE NEWLINE / COMMAND PIPELINING — postscreen pre-greet filtering catching bots.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"rawdb-mail\", program=\"postfix/postscreen\"} |~ `HANGUP|REJECT|DNSBL|BARE NEWLINE|COMMAND PIPELINING|PREGREET` [$__range]))",
          "refId": "A"

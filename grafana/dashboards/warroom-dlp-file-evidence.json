        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum by (nas_host, source_app, action) (count_over_time({job=\"warroom-dlp-event-collector\", nas_host=~\"$nas\", source_app=~\"synology_drive|file_station|nas_file_service\", action=~\"webapp_file_open|webapp_file_preview|webapp_file_download|webapp_file_export|public_share_page_load|sharing_link_access|file_activity|file_read|file_write|file_delete|file_rename|capability_gap\"}[5m]))",

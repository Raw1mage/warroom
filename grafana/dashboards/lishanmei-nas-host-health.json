    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "最近 5 分鐘收到的 host health snapshot 數。若為 0，代表 Warroom 端 SSH transient payload 沒有送達 Loki。",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", source_channel=\"host_health\", source_app=\"nas_host_health\", nas_host=~\"$nas\"}[5m])) or vector(0)",
          "legendFormat": "snapshots",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Host health snapshots / 5m",
      "type": "stat"
    },
    {

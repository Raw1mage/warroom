{
  "title": "AI Security - LLM Telemetry Group",
  "uid": "aisecurity-llm-telemetry-group",
  "schemaVersion": 39,
  "version": 4,
  "tags": ["aisecurity", "opencms", "llm", "sidecar", "gpu", "warroom"],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "sidecar_job",
        "type": "constant",
        "query": "aisecurity-llm-sidecar",
        "current": {"text": "aisecurity-llm-sidecar", "value": "aisecurity-llm-sidecar"}
      },
      {
        "name": "gpu_job",
        "type": "constant",
        "query": "aisecurity-gpu",
        "current": {"text": "aisecurity-gpu", "value": "aisecurity-gpu"}
      },
      {
        "name": "service",
        "type": "constant",
        "query": "aisecurity-llm-sidecar",
        "current": {"text": "aisecurity-llm-sidecar", "value": "aisecurity-llm-sidecar"}
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Runtime Health",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "type": "stat",
      "title": "Sidecar Up",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "up{job=\"$sidecar_job\"}", "legendFormat": "sidecar"}],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1}
    },
    {
      "type": "stat",
      "title": "GPU Exporter Up",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "up{job=\"$gpu_job\"}", "legendFormat": "gpu"}],
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1}
    },
    {
      "type": "stat",
      "title": "Upstream Errors (5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "increase(llm_sidecar_upstream_errors_total[5m])", "legendFormat": "errors"}],
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1}
    },
    {
      "type": "stat",
      "title": "GPU Scrape Success",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "aisecurity_gpu_scrape_success", "legendFormat": "{{name}}"}],
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1}
    },
    {
      "type": "row",
      "title": "Request Traffic",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}
    },
    {
      "type": "timeseries",
      "title": "Chat Request Rate",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "rate(llm_sidecar_requests_total[5m])", "legendFormat": "chat requests/s"}],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 6}
    },
    {
      "type": "timeseries",
      "title": "Streaming Requests",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "rate(llm_sidecar_streaming_requests_total[5m])", "legendFormat": "streaming/s"}],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 6}
    },
    {
      "type": "timeseries",
      "title": "Catch-all Proxy Requests",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "rate(llm_sidecar_catchall_requests_total[5m])", "legendFormat": "fallback/s"}],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 6}
    },
    {
      "type": "row",
      "title": "Latency and Reliability",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14}
    },
    {
      "type": "timeseries",
      "title": "Sidecar Latency Quantiles",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(llm_sidecar_request_latency_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(llm_sidecar_request_latency_seconds_bucket[5m]))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(llm_sidecar_request_latency_seconds_bucket[5m]))", "legendFormat": "p99"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15}
    },
    {
      "type": "timeseries",
      "title": "Upstream Error Rate",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "rate(llm_sidecar_upstream_errors_total[5m])", "legendFormat": "errors/s"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15}
    },
    {
      "type": "row",
      "title": "Prompt Fingerprint and Cache Signals",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23}
    },
    {
      "type": "timeseries",
      "title": "Repeated Prefix Events",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "increase(llm_sidecar_repeated_prefix_total[5m])", "legendFormat": "repeated prefixes"}],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24}
    },
    {
      "type": "table",
      "title": "Recent Fingerprints",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{service=\"$service\"} | json | line_format \"{{.ts}} trace={{.trace_id}} model={{.model}} cache={{.cache_event}} fingerprint={{.prompt_fingerprint}} prefix={{.prefix_hash}}\""}],
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 24}
    },
    {
      "type": "row",
      "title": "Tokens, Tools, and OpenCMS Metadata",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32}
    },
    {
      "type": "timeseries",
      "title": "Prompt Tokens from Logs",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "sum(sum_over_time({service=\"$service\"} | json | unwrap prompt_tokens [5m]))", "legendFormat": "prompt tokens / 5m"}],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 33}
    },
    {
      "type": "timeseries",
      "title": "Completion Tokens from Logs",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "sum(sum_over_time({service=\"$service\"} | json | unwrap completion_tokens [5m]))", "legendFormat": "completion tokens / 5m"}],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 33}
    },
    {
      "type": "table",
      "title": "OpenCMS Request Metadata",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{service=\"$service\"} | json | line_format \"{{.ts}} session={{.opencode_session_id}} account={{.opencode_account_id}} project={{.opencode_project}} request={{.opencode_request_id}} client={{.opencode_client}} tools={{.tool_count}} messages={{.message_count}}\"", "maxLines": 100}],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 33}
    },
    {
      "type": "row",
      "title": "KV Cache External Observation",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 41}
    },
    {
      "type": "stat",
      "title": "KV Experiment Requests",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "sum(count_over_time({service=\"$service\"} | json | opencode_client=\"kv-cache-external-observe\" [$__range]))", "legendFormat": "requests"}],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 42}
    },
    {
      "type": "stat",
      "title": "Repeated Prefix Hits",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "sum(count_over_time({service=\"$service\"} | json | opencode_client=\"kv-cache-external-observe\" | cache_event=\"repeated_prefix\" [$__range]))", "legendFormat": "repeated"}],
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 42}
    },
    {
      "type": "stat",
      "title": "Candidate Avg Latency",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "avg(avg_over_time({service=\"$service\"} | json | opencode_client=\"kv-cache-external-observe\" | cache_event=\"candidate\" | unwrap latency_ms [$__range]))", "legendFormat": "candidate ms"}],
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 42}
    },
    {
      "type": "stat",
      "title": "Repeated Avg Latency",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "avg(avg_over_time({service=\"$service\"} | json | opencode_client=\"kv-cache-external-observe\" | cache_event=\"repeated_prefix\" | unwrap latency_ms [$__range]))", "legendFormat": "repeated ms"}],
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 42}
    },
    {
      "type": "timeseries",
      "title": "KV Latency Distribution",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "avg(quantile_over_time(0.50, {service=\"$service\"} | json | opencode_client=\"kv-cache-external-observe\" | cache_event=\"candidate\" | unwrap latency_ms [5m]))", "legendFormat": "candidate p50"},
        {"expr": "avg(quantile_over_time(0.95, {service=\"$service\"} | json | opencode_client=\"kv-cache-external-observe\" | cache_event=\"candidate\" | unwrap latency_ms [5m]))", "legendFormat": "candidate p95"},
        {"expr": "avg(quantile_over_time(0.50, {service=\"$service\"} | json | opencode_client=\"kv-cache-external-observe\" | cache_event=\"repeated_prefix\" | unwrap latency_ms [5m]))", "legendFormat": "repeated p50"},
        {"expr": "avg(quantile_over_time(0.95, {service=\"$service\"} | json | opencode_client=\"kv-cache-external-observe\" | cache_event=\"repeated_prefix\" | unwrap latency_ms [5m]))", "legendFormat": "repeated p95"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 46}
    },
    {
      "type": "stat",
      "title": "KV Token Summary",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "avg(avg_over_time({service=\"$service\"} | json | opencode_client=\"kv-cache-external-observe\" | cache_event=\"candidate\" | unwrap prompt_tokens [$__range]))", "legendFormat": "candidate prompt tokens"},
        {"expr": "avg(avg_over_time({service=\"$service\"} | json | opencode_client=\"kv-cache-external-observe\" | cache_event=\"repeated_prefix\" | unwrap prompt_tokens [$__range]))", "legendFormat": "repeated prompt tokens"},
        {"expr": "avg(avg_over_time({service=\"$service\"} | json | opencode_client=\"kv-cache-external-observe\" | cache_event=\"candidate\" | unwrap completion_tokens [$__range]))", "legendFormat": "candidate completion tokens"},
        {"expr": "avg(avg_over_time({service=\"$service\"} | json | opencode_client=\"kv-cache-external-observe\" | cache_event=\"repeated_prefix\" | unwrap completion_tokens [$__range]))", "legendFormat": "repeated completion tokens"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 46}
    },
    {
      "type": "timeseries",
      "title": "KV Experiment GPU Pressure",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "aisecurity_gpu_utilization_percent", "legendFormat": "GPU load %"},
        {"expr": "aisecurity_gpu_memory_utilization_percent", "legendFormat": "VRAM %"}
      ],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 54}
    },
    {
      "type": "table",
      "title": "KV Experiment Trace Comparison",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{service=\"$service\"} | json | opencode_client=\"kv-cache-external-observe\" | line_format \"{{.ts}} event={{.cache_event}} latency={{.latency_ms}}ms prompt={{.prompt_tokens}} completion={{.completion_tokens}} trace={{.trace_id}} request={{.opencode_request_id}} fp={{.prompt_fingerprint}} prefix={{.prefix_hash}}\"", "maxLines": 100}],
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 54}
    },
    {
      "type": "row",
      "title": "GPU Telemetry",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 62}
    },
    {
      "type": "stat",
      "title": "GPU Load Now",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "aisecurity_gpu_utilization_percent", "legendFormat": "{{name}} util %"}],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 63}
    },
    {
      "type": "stat",
      "title": "VRAM Used Now",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "aisecurity_gpu_memory_utilization_percent", "legendFormat": "{{name}} vram %"}],
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 63}
    },
    {
      "type": "stat",
      "title": "GPU Temperature Now",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "aisecurity_gpu_temperature_celsius", "legendFormat": "{{name}} °C"}],
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 63}
    },
    {
      "type": "stat",
      "title": "GPU Fan Now",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "aisecurity_gpu_fan_speed_percent", "legendFormat": "{{name}} fan %"}],
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 63}
    },
    {
      "type": "timeseries",
      "title": "GPU Load Trend",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "aisecurity_gpu_utilization_percent", "legendFormat": "{{name}} load %"}],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 67}
    },
    {
      "type": "timeseries",
      "title": "VRAM Utilization Trend",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "aisecurity_gpu_memory_utilization_percent", "legendFormat": "{{name}} vram %"}],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 67}
    },
    {
      "type": "timeseries",
      "title": "Temperature and Fan Trend",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "aisecurity_gpu_temperature_celsius", "legendFormat": "{{name}} °C"},
        {"expr": "aisecurity_gpu_fan_speed_percent", "legendFormat": "{{name}} fan %"}
      ],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 67}
    },
    {
      "type": "timeseries",
      "title": "VRAM Used vs Total",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "aisecurity_gpu_memory_used_bytes", "legendFormat": "{{name}} used"},
        {"expr": "aisecurity_gpu_memory_total_bytes", "legendFormat": "{{name}} total"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 75}
    },
    {
      "type": "timeseries",
      "title": "GPU Power Draw",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "aisecurity_gpu_power_draw_watts", "legendFormat": "{{name}} watts"},
        {"expr": "aisecurity_gpu_power_limit_watts", "legendFormat": "{{name}} power limit"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 75}
    },
    {
      "type": "row",
      "title": "Raw Trace Logs",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 83}
    },
    {
      "type": "logs",
      "title": "Sidecar JSONL Events",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{service=\"$service\"} | json"}],
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 84}
    }
  ]
}

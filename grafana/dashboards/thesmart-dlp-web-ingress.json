  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum by (source_app, action) (count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\", source_app!=\"collector\"}[5m]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "利善美 / DLP evidence activity trend",
      "type": "timeseries",
      "description": "以 collector 實際回收的正規化 NAS evidence 為資料源；File Station / Drive 是否覆蓋請看 coverage panel，不用 No data 假裝成活動。"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\", source_app!=\"collector\"}[15m])) or vector(0)",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "最近區間 DLP evidence 數",
      "type": "stat",
      "description": "目前時間範圍內 thesmart 正規化 DLP 事件總數。"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "-1": {
                  "color": "red",
                  "index": 0,
                  "text": "gap"
                },
                "0": {
                  "color": "orange",
                  "index": 1,
                  "text": "no_events"
                },
                "1": {
                  "color": "green",
                  "index": 2,
                  "text": "active"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "max by (covered_source_app) (last_over_time({job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\", source_channel=\"collector_coverage\", action=\"coverage_status\"} | json | unwrap coverage_value [15m]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "收集器狀態",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "covered_source_app": 0,
              "Value": 1
            },
            "renameByName": {
              "Value": "狀態",
              "covered_source_app": "來源"
            }
          }
        }
      ],
      "type": "table",
      "description": "每列是一個 collector source 的最近覆蓋狀態：active=有資料、no_events=目前無事件、gap=收集缺口；這不是使用者活動量。"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": true,
        "showLabels": false,
        "showTime": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "{job=\"warroom-dlp-event-collector\", nas_host=\"thesmart\"} | json | line_format \"{{__timestamp__ | date \\\"2006-01-02T15:04:05Z07:00\\\"}} {{if .source_ip}}{{.source_ip}}{{else}}-{{end}} {{if .actor}}{{.actor}}{{else}}-{{end}} {{.source_app}} {{.action}} \\\"{{if .display_path}}{{.display_path}}{{else if .file_name}}{{.file_name}}{{else}}-{{end}}\\\" {{if .network_protocol}}{{.network_protocol}}{{else if .protocol}}{{.protocol}}{{else}}-{{end}}\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "利善美資料安全原始證據流",
      "type": "logs",
      "description": "顯示 thesmart 的正規化 DLP evidence payload。"
    }
  ],

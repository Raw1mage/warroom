    {
      "id": 20,
      "type": "table",
      "title": "Coverage by (NAS × Field) — last 5m",
      "description": "Coverage column color = ratio. Status column color = active/no_events/no_field.",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "max by (nas_host, field_name, coverage_status, present_count, event_count) (last_over_time({source_channel=\"collector_coverage\", action=\"field_coverage_status\"} | json | __error__=\"\" | unwrap coverage_value [5m]))",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__error__": true
            },
            "indexByName": {
              "nas_host": 0,
              "field_name": 1,
              "coverage_status": 2,
              "present_count": 3,
              "event_count": 4,
              "Value": 5
            },
            "renameByName": {
              "nas_host": "NAS",
              "field_name": "Field",
              "coverage_status": "Status",
              "present_count": "Present",
              "event_count": "Total",
              "Value": "Coverage"
            }
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "NAS",
                "Field",
                "Status",
                "Present",
                "Total",
                "Coverage"
              ]
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Coverage",
                "desc": false
              },
              {
                "field": "NAS",
                "desc": false
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Coverage"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red"
                    },
                    {
                      "color": "orange",
                      "value": 0.3
                    },
                    {
                      "color": "green",
                      "value": 0.7
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "no_events": {
                        "color": "red",
                        "index": 0
                      },
                      "active": {
                        "color": "green",
                        "index": 1
                      },
                      "no_field": {
                        "color": "orange",
                        "index": 2
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      }
    },

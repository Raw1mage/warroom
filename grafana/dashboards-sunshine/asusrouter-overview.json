    {
      "id": 13,
      "type": "table",
      "title": "Active bans (truth: warroom state)",
      "description": "Per-IP banned_at / expires_at / remaining time. Sourced from devices/.../state/banned.json via the exporter.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 37
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "asusrouter_ban_banned_at_seconds",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "asusrouter_ban_expires_at_seconds",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "expr": "asusrouter_ban_expires_at_seconds - time()",
          "refId": "C",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "src_ip",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "device": true,
              "device 1": true,
              "device 2": true,
              "device 3": true,
              "instance": true,
              "instance 1": true,
              "instance 2": true,
              "instance 3": true,
              "job": true,
              "job 1": true,
              "job 2": true,
              "job 3": true
            },
            "indexByName": {
              "src_ip": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3
            },
            "renameByName": {
              "src_ip": "Attacker IP",
              "Value #A": "Banned at (epoch)",
              "Value #B": "Expires at (epoch)",
              "Value #C": "Remaining (s)"
            }
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              {
                "targetField": "Banned at (epoch)",
                "destinationType": "time"
              },
              {
                "targetField": "Expires at (epoch)",
                "destinationType": "time"
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Remaining (s)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red"
                    },
                    {
                      "color": "orange",
                      "value": 300
                    },
                    {
                      "color": "green",
                      "value": 1800
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    },

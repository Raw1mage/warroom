    {
      "type": "row",
      "id": 200,
      "title": "Multi-channel attacker matrix",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "panels": []
    },
    {
      "id": 10,
      "type": "table",
      "title": "Cross-channel correlation (IP × channel × GeoIP)",
      "description": "Each row joins IP across SSH/NGINX/MAIL Loki counts and GeoIP enrichment. Score = number of channels with non-zero hits. Sort by Score, then totals.",
      "gridPos": {
        "h": 18,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "topk(200, sum by (src_ip) (count_over_time({job=\"asus-router\", prog=\"kernel\"} |= `WSLSSH-` | regexp `SRC=(?P<src_ip>[\\d.]+)` [$__range])))",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "topk(200, sum by (src_ip) (count_over_time({job=\"rawdb-nginx\"} | regexp `client: (?P<src_ip>[\\d.]+)` [$__range])))",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "topk(200, sum by (src_ip) (count_over_time({job=\"rawdb-mail\"} | regexp `(?:from \\[|rip=)(?P<src_ip>[\\d.]+)` [$__range])))",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "D",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "warroom_ip_info",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "^ip$",
            "renamePattern": "src_ip"
          }
        },
        {
          "id": "joinByField",
          "options": {
            "byField": "src_ip",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "latitude": true,
              "longitude": true
            },
            "indexByName": {
              "src_ip": 0,
              "country_iso": 1,
              "city": 2,
              "asn_org": 3,
              "asn_number": 4,
              "Value #A": 5,
              "Value #B": 6,
              "Value #C": 7
            },
            "renameByName": {
              "src_ip": "IP",
              "country_iso": "Country",
              "city": "City",
              "asn_org": "AS Org",
              "asn_number": "ASN",
              "Value #A": "SSH hits",
              "Value #B": "Nginx hits",
              "Value #C": "Mail hits"
            }
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "IP",
                "Country",
                "City",
                "AS Org",
                "ASN",
                "SSH hits",
                "Nginx hits",
                "Mail hits"
              ]
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "reduceRow",
            "reduce": {
              "reducer": "count",
              "include": [
                "SSH hits",
                "Nginx hits",
                "Mail hits"
              ]
            },
            "alias": "Channels hit"
          }
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "reduceRow",
            "reduce": {
              "reducer": "sum",
              "include": [
                "SSH hits",
                "Nginx hits",
                "Mail hits"
              ]
            },
            "alias": "Total hits"
          }
        },
        {
          "id": "filterByValue",
          "options": {
            "filters": [
              {
                "fieldName": "Total hits",
                "config": {
                  "id": "greater",
                  "options": {
                    "value": 0
                  }
                }
              }
            ],
            "type": "include",
            "match": "any"
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Channels hit",
                "desc": true
              },
              {
                "field": "Total hits",
                "desc": true
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Channels hit"
            },
            "properties": [
              {
                "id": "custom.cellOptions",

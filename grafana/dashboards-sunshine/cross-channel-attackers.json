        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "count(count by (src_ip) (count_over_time({job=~\"asus-router|rawdb-nginx|rawdb-mail\"} | regexp `(?:SRC=|client: |from \\[|rip=)(?P<src_ip>[0-9.]+)` [$__range])))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }

{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "title": "ASUS Router fail2ban (WSLSSH WAN 2122)",
  "uid": "asusrouter-fail2ban",
  "tags": [
    "asusrouter",
    "fail2ban",
    "security",
    "陽光沙灘"
  ],
  "timezone": "Asia/Taipei",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "WSLSSH SYNs (selected range)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"asus-router\", prog=\"kernel\"} |= `WSLSSH-` [$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Unique attacker IPs",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "count(count by (src_ip) (count_over_time({job=\"asus-router\", prog=\"kernel\"} |= `WSLSSH-` | regexp `SRC=(?P<src_ip>[\\d.]+)` [$__range])))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active bans (router truth)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "count(count by (src_ip) (count_over_time({job=\"asus-router\"} |~ `ban: ` [$__range])))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "WSLSSH SYN rate",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(rate({job=\"asus-router\", prog=\"kernel\"} |= `WSLSSH-` [1m]))",
          "refId": "A",
          "legendFormat": "SYNs/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Top attackers (selected range)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "topk(20, sum by (src_ip) (count_over_time({job=\"asus-router\", prog=\"kernel\"} |= `WSLSSH-` | regexp `SRC=(?P<src_ip>[\\d.]+)` [$__range])))",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "src_ip": "Attacker IP",
              "Value": "SYN count"
            }
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Recent WSLSSH attempts",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{job=\"asus-router\", prog=\"kernel\"} |= `WSLSSH-` | regexp `SRC=(?P<src_ip>[\\d.]+).*SPT=(?P<sport>\\d+)` | line_format `{{.src_ip}}:{{.sport}}`",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": false,
        "enableLogDetails": true
      }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "All router events (last)",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{job=\"asus-router\"} | line_format `[{{.prog}}/{{.prio}}] {{__line__}}`",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true
      }
    }
  ]
}

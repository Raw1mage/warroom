{
  "title": "AI Security - LLM Telemetry Group",
  "uid": "aisecurity-llm-telemetry-group",
  "schemaVersion": 39,
  "version": 25,
  "tags": [
    "aisecurity",
    "opencms",
    "llm",
    "sidecar",
    "gpu",
    "vllm",
    "warroom"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "sidecar_job",
        "type": "constant",
        "query": "aisecurity-llm-sidecar",
        "current": {
          "text": "aisecurity-llm-sidecar",
          "value": "aisecurity-llm-sidecar"
        }
      },
      {
        "name": "gpu_job",
        "type": "constant",
        "query": "aisecurity-gpu",
        "current": {
          "text": "aisecurity-gpu",
          "value": "aisecurity-gpu"
        }
      },
      {
        "name": "runtime_job",
        "type": "constant",
        "query": "aisecurity-vllm-runtime",
        "current": {
          "text": "aisecurity-vllm-runtime",
          "value": "aisecurity-vllm-runtime"
        }
      },
      {
        "name": "service",
        "type": "constant",
        "query": "aisecurity-llm-sidecar",
        "current": {
          "text": "aisecurity-llm-sidecar",
          "value": "aisecurity-llm-sidecar"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "1. Pipeline Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 19,
      "type": "state-timeline",
      "title": "Three-Port UP/DOWN Timeline",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "max(up{job=\"$runtime_job\"})", "legendFormat": "7730 runtime" },
        { "expr": "max(up{job=\"$sidecar_job\"})", "legendFormat": "7731 sidecar" },
        { "expr": "max(up{job=\"$gpu_job\"})", "legendFormat": "7732 gpu exporter" }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 1 },
      "options": {
        "alignValue": "left",
        "legend": { "displayMode": "hidden", "placement": "bottom", "showLegend": false },
        "mergeValues": true,
        "rowHeight": 0.9,
        "showValue": "always",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "text": "DOWN" },
                "1": { "color": "green", "text": "UP" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "2. Traffic & Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Chat Request Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(llm_sidecar_requests_total[5m])", "legendFormat": "chat requests/s" }
      ],
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 9 }
    },
    {
      "type": "timeseries",
      "title": "Sidecar Latency Quantiles",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(llm_sidecar_request_latency_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(llm_sidecar_request_latency_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(llm_sidecar_request_latency_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 9 }
    },
    {
      "type": "timeseries",
      "title": "Sidecar Event Rate",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "sum(count_over_time({service=\"$service\"} | json [5m]))", "legendFormat": "events / 5m" }
      ],
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 9 }
    },
    {
      "type": "timeseries",
      "title": "Token Throughput",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "sum(sum_over_time({service=\"$service\"} | json | unwrap prompt_tokens [5m]))", "legendFormat": "prompt tokens / 5m" },
        { "expr": "sum(sum_over_time({service=\"$service\"} | json | unwrap completion_tokens [5m]))", "legendFormat": "completion tokens / 5m" }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 16 }
    },
    {
      "type": "timeseries",
      "title": "OpenCMS Client / Project Mix",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "sum by (opencode_client) (count_over_time({service=\"$service\"} | json | opencode_client != \"\" [5m]))", "legendFormat": "client={{opencode_client}}" },
        { "expr": "sum by (opencode_project) (count_over_time({service=\"$service\"} | json | opencode_project != \"\" [5m]))", "legendFormat": "project={{opencode_project}}" }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 16 }
    },
    {
      "type": "row",
      "title": "3. Proxy Capacity & Backpressure (7731)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "In-flight Requests",
      "description": "Chat completion permits currently held.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 24 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(llm_sidecar_inflight)" }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cap (max in-flight)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 24 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(llm_sidecar_max_concurrent)" }
      ],
      "options": { "colorMode": "none", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Rejected (range total)",
      "description": "Requests dropped after waiting longer than --acquire-timeout-secs.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 24 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(llm_sidecar_rejected_concurrency_total[$__range]))" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Queue Wait avg (5m)",
      "description": "Mean time chat requests spent waiting for a permit.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 24 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(llm_sidecar_queue_wait_seconds_sum[5m])) / clamp_min(sum(rate(llm_sidecar_queue_wait_seconds_count[5m])), 1e-9)" }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "In-flight Over Time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 29 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(llm_sidecar_inflight)", "legendFormat": "inflight" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(llm_sidecar_max_concurrent)", "legendFormat": "cap" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Queue Wait Rate + Rejections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 29 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(llm_sidecar_queue_wait_seconds_sum[5m]))", "legendFormat": "queue wait sec/s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(llm_sidecar_rejected_concurrency_total[5m]))", "legendFormat": "rejected/s" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "type": "row",
      "title": "4. Collision & Reuse Candidate Signals",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }
    },
    {
      "type": "bargauge",
      "title": "Source / Fingerprint / Prefix Cardinality",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "count(sum by (opencode_session_id) (count_over_time({service=\"$service\"} | json | opencode_session_id != \"\" [$__range])))", "legendFormat": "active sessions" },
        { "expr": "count(sum by (opencode_account_id) (count_over_time({service=\"$service\"} | json | opencode_account_id != \"\" [$__range])))", "legendFormat": "active accounts" },
        { "expr": "count(sum by (prompt_fingerprint) (count_over_time({service=\"$service\"} | json | prompt_fingerprint != \"\" [$__range])))", "legendFormat": "unique fingerprints" },
        { "expr": "count(sum by (prefix_hash) (count_over_time({service=\"$service\"} | json | prefix_hash != \"\" [$__range])))", "legendFormat": "unique prefixes" }
      ],
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 37 },
      "options": {
        "displayMode": "gradient",
        "maxVizHeight": 300,
        "minVizHeight": 16,
        "minVizWidth": 8,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Fingerprint Cache Event Mix",
      "description": "Includes repeated_prefix, candidate, and any other cache_event values.",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "sum by (cache_event) (count_over_time({service=\"$service\"} | json | cache_event != \"\" [5m]))", "legendFormat": "{{cache_event}}" }
      ],
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 37 }
    },
    {
      "type": "timeseries",
      "title": "Fingerprint / Prefix Observation Volume",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "sum(count_over_time({service=\"$service\"} | json | prompt_fingerprint != \"\" [5m]))", "legendFormat": "fingerprint observations / 5m" },
        { "expr": "sum(count_over_time({service=\"$service\"} | json | prefix_hash != \"\" [5m]))", "legendFormat": "prefix observations / 5m" }
      ],
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 37 }
    },
    {
      "type": "row",
      "title": "6. vLLM Runtime Internals (7730)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Runtime Cache Hit & Usage",
      "description": "GPU/CPU prefix hit rate and KV cache usage over time. Replaces the prior donut chart, which mis-rendered time-varying gauges as a pie slice.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "avg(vllm_gpu_prefix_cache_hit_rate{job=\"$runtime_job\"})", "legendFormat": "GPU prefix hit rate" },
        { "expr": "avg(vllm_cpu_prefix_cache_hit_rate{job=\"$runtime_job\"})", "legendFormat": "CPU prefix hit rate" },
        { "expr": "avg(vllm_gpu_cache_usage_perc{job=\"$runtime_job\"})", "legendFormat": "GPU KV cache usage" },
        { "expr": "avg(vllm_cpu_cache_usage_perc{job=\"$runtime_job\"})", "legendFormat": "CPU KV cache usage" }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 58 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Runtime Token Throughput",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(vllm_prompt_tokens_total{job=\"$runtime_job\"}[$__rate_interval]))", "legendFormat": "prefill tokens/s" },
        { "expr": "sum(rate(vllm_generation_tokens_total{job=\"$runtime_job\"}[$__rate_interval]))", "legendFormat": "generation tokens/s" }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 58 }
    },
    {
      "type": "row",
      "title": "7. GPU Resource (7732)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 72 }
    },
    {
      "type": "timeseries",
      "title": "GPU Load Trend",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "aisecurity_gpu_utilization_percent", "legendFormat": "{{name}} load %" }
      ],
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 73 }
    },
    {
      "type": "timeseries",
      "title": "VRAM Used (GB)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "aisecurity_gpu_memory_used_bytes / 1024 / 1024 / 1024", "legendFormat": "{{name}} VRAM GB" }
      ],
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 73 },
      "fieldConfig": { "defaults": { "unit": "decgbytes" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Temperature & Fan Trend",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "aisecurity_gpu_temperature_celsius", "legendFormat": "{{name}} °C" },
        { "expr": "aisecurity_gpu_fan_speed_percent", "legendFormat": "{{name}} fan %" }
      ],
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 73 }
    },
    {
      "type": "timeseries",
      "title": "GPU Power Draw",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "aisecurity_gpu_power_draw_watts", "legendFormat": "{{name}} watts" },
        { "expr": "aisecurity_gpu_power_limit_watts", "legendFormat": "{{name}} power limit" }
      ],
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 73 },
      "fieldConfig": { "defaults": { "unit": "watt" }, "overrides": [] }
    },
    {
      "type": "row",
      "title": "8. Cross-Port Causal Checks",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 80 }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Request Rate vs Runtime Cache Activity",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(llm_sidecar_requests_total{job=\"$sidecar_job\"}[5m]))", "legendFormat": "7731 requests/s" },
        { "expr": "sum(rate(vllm_prompt_tokens_total{job=\"$runtime_job\"}[$__rate_interval]))", "legendFormat": "7730 prefill tokens/s" },
        { "expr": "sum(rate(vllm_generation_tokens_total{job=\"$runtime_job\"}[$__rate_interval]))", "legendFormat": "7730 generation tokens/s" },
        { "expr": "avg(vllm_gpu_prefix_cache_hit_rate{job=\"$runtime_job\"})", "legendFormat": "7730 GPU prefix hit rate" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 81 }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Latency vs Cache Benefit Signals",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(llm_sidecar_request_latency_seconds_bucket{job=\"$sidecar_job\"}[5m]))", "legendFormat": "7731 latency p50" },
        { "expr": "histogram_quantile(0.95, rate(llm_sidecar_request_latency_seconds_bucket{job=\"$sidecar_job\"}[5m]))", "legendFormat": "7731 latency p95" },
        { "expr": "avg(vllm_gpu_prefix_cache_hit_rate{job=\"$runtime_job\"})", "legendFormat": "7730 GPU prefix hit rate" },
        { "expr": "sum(rate(vllm_num_preemptions_total{job=\"$runtime_job\"}[$__rate_interval]))", "legendFormat": "7730 preemptions/s" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 81 }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Runtime Cache Signals vs GPU Pressure",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "aisecurity_gpu_utilization_percent{job=\"$gpu_job\"}", "legendFormat": "7732 GPU load %" },
        { "expr": "aisecurity_gpu_memory_utilization_percent{job=\"$gpu_job\"}", "legendFormat": "7732 VRAM %" },
        { "expr": "avg(vllm_gpu_prefix_cache_hit_rate{job=\"$runtime_job\"})", "legendFormat": "7730 GPU prefix hit rate" },
        { "expr": "avg(vllm_gpu_cache_usage_perc{job=\"$runtime_job\"})", "legendFormat": "7730 GPU KV usage" }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 89 }
    },
    {
      "type": "row",
      "title": "9. Semantic Response Cache Leak Demo",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 97 }
    },
    {
      "id": 30,
      "type": "table",
      "title": "Poisoning Reality Show: A Seeds, B Sees",
      "description": "Log-style semantic_response_cache_demo timeline: account A poisons a fake response cache entry, account B observes the poisoned cached response. Fake data only; not vLLM KV collision.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "cache_demo_timeline_event_info{job=\"aisecurity-semantic-cache-demo\",scenario=\"cache_poisoning\"}", "format": "table", "instant": true }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Value": true,
              "__name__": true,
              "cache_owner": true,
              "instance": true,
              "job": true,
              "scenario": true,
              "served_profile": true,
              "service": true,
              "telemetry_scope": true
            },
            "indexByName": {
              "Time": 0,
              "actor": 1,
              "step": 2,
              "dialog": 3,
              "event": 4,
              "mode": 5,
              "risk": 6
            },
            "renameByName": {
              "Time": "time",
              "actor": "account"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "cellOptions": { "type": "auto" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "time" }, "properties": [{ "id": "custom.width", "value": 165 }] },
          { "matcher": { "id": "byName", "options": "account" }, "properties": [{ "id": "custom.width", "value": 95 }] },
          { "matcher": { "id": "byName", "options": "step" }, "properties": [{ "id": "custom.width", "value": 55 }] },
          { "matcher": { "id": "byName", "options": "dialog" }, "properties": [{ "id": "custom.width", "value": 235 }] },
          { "matcher": { "id": "byName", "options": "event" }, "properties": [{ "id": "custom.width", "value": 260 }] },
          { "matcher": { "id": "byName", "options": "mode" }, "properties": [{ "id": "custom.width", "value": 95 }] },
          { "matcher": { "id": "byName", "options": "risk" }, "properties": [{ "id": "custom.width", "value": 230 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 98 }
    },
    {
      "id": 31,
      "type": "stat",

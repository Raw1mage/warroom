HOST=192.168.100.1
USER=admin
SSH_KEY="$HOME/.ssh/id_ed25519"
MODEL=RT-AX86U
WAN_IFACE=ppp0

# Hard whitelist — never banned regardless of activity.
# Regex matched against $SRC literal. Defaults cover RFC1918 private space
# + NCU subnet (140.115.0.0/16, user's school) since legit traffic from
# there shows up across multiple channels and would otherwise be flagged
# by cross-channel correlation.
WHITELIST_RE='^(127\.|192\.168\.|10\.|172\.(1[6-9]|2[0-9]|3[0-1])\.|140\.115\.)'

# Extra exact IPs (space-separated), e.g. trusted school/office static IPs.
WHITELIST_EXTRA=""

# Auto-generated SNMP v2c community (LAN-only).
SNMP_COMMUNITY=warroom-ubvcXq9yxk1p

          { "id": "A62", "title": "規則與基線偵測", "description": "套用 9 條確定性規則與 rolling baseline（含 GeoIP），產生帶嚴重度的 candidate。", "decomposition": null },
          { "id": "A63", "title": "LLM 分流判斷", "description": "把去識別化證據送 LLM triage，取得是否異常、信心度、判斷理由與建議動作。", "decomposition": null },
